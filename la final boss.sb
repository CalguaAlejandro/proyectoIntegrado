Controls.ButtonClicked = boton

Sub boton
  ultimo_boton = Controls.LastClickedButton
  If ultimo_boton = uno Then
    boton1()
  ElseIf ultimo_boton = dos Then
    boton2()
  ElseIf ultimo_boton = tres Then
    boton3()
  ElseIf ultimo_boton = cuatro Then
    boton4()
  ElseIf ultimo_boton = cinco Then
    boton5()
  ElseIf ultimo_boton = seis Then
    boton6()
  ElseIf ultimo_boton = siete Then
    boton7()
  ElseIf ultimo_boton = ocho Then
    boton8()
  ElseIf ultimo_boton = nueve Then
    boton9()
  ElseIf ultimo_boton = cero Then
    boton0()
  ElseIf ultimo_boton = punto Then
    boton11()
  ElseIf ultimo_boton = prt1 Then
    botonP1()
  ElseIf ultimo_boton = prt2 Then
    botonP2()
  ElseIf ultimo_boton = ON Then
    botonLimpiar()
  ElseIf ultimo_boton = mas Then
    botonMas()
  ElseIf ultimo_boton = menos Then
    botonMenos()
  ElseIf ultimo_boton = por Then
    botonPor()
  ElseIf ultimo_boton = div Then
    botonDiv()
  ElseIf ultimo_boton = sin Then
    botonSin()
  ElseIf ultimo_boton = cos Then
    botonCos()
  ElseIf ultimo_boton = tan Then
    botonTan()
  ElseIf ultimo_boton = Ln Then
    botonLn()
  ElseIf ultimo_boton = log Then
    botonLog()
  ElseIf ultimo_boton = a Then
    botonA()
  ElseIf ultimo_boton = b Then
    botonB()
  ElseIf ultimo_boton = yx Then
    botonYX()
  ElseIf ultimo_boton = x2 Then
    botonX2()
  ElseIf ultimo_boton = raiz Then
    botonRaiz()
  ElseIf ultimo_boton = CE Then
    botonCE()
  ElseIf ultimo_boton = igual Then
    botonIgual()
  ElseIf ultimo_boton = masmenos Then
    botonMasMenos()
  ElseIf ultimo_boton = btnCuad Then
    botonCuadratica()
  ElseIf ultimo_boton = btnLineal Then
    botonLineal()
  ElseIf ultimo_boton = btnSist Then
    botonSistema()
  ElseIf ultimo_boton = btnEnergia Then
    botonEnergia()
  EndIf
EndSub

