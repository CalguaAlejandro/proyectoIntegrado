  If largo > 0 Then
    Controls.SetTextBoxText(caja, Text.GetSubText(Controls.GetTextBoxText(caja),1,largo-1))
  EndIf
EndSub
Sub botonLimpiar
  Controls.SetTextBoxText(caja,"")
EndSub
Sub botonMasMenos
  valor = Controls.GetTextBoxText(caja)
  If valor <> "" Then
    Controls.SetTextBoxText(caja, valor * -1)
  EndIf
EndSub

' ══════════════════════════════════════════════════════
' BOTON IGUAL - calcula la expresion del visor
' ══════════════════════════════════════════════════════
Sub botonIgual
  expresion = Controls.GetTextBoxText(caja)

  posicion = Text.GetIndexOf(expresion, " + ")
  If posicion > 0 Then
    parte1 = Text.GetSubText(expresion, 1, posicion - 1)
    parte2 = Text.GetSubTextToEnd(expresion, posicion + 3)
    Controls.SetTextBoxText(caja, parte1 + parte2)
    GoTo finIgual
  EndIf

  posicion = Text.GetIndexOf(expresion, " - ")
  If posicion > 0 Then
    parte1 = Text.GetSubText(expresion, 1, posicion - 1)
    parte2 = Text.GetSubTextToEnd(expresion, posicion + 3)
    Controls.SetTextBoxText(caja, parte1 - parte2)
    GoTo finIgual
  EndIf

  posicion = Text.GetIndexOf(expresion, " * ")
  If posicion > 0 Then
    parte1 = Text.GetSubText(expresion, 1, posicion - 1)
    parte2 = Text.GetSubTextToEnd(expresion, posicion + 3)
    Controls.SetTextBoxText(caja, parte1 * parte2)
    GoTo finIgual
  EndIf

  posicion = Text.GetIndexOf(expresion, " / ")
  If posicion > 0 Then
    parte1 = Text.GetSubText(expresion, 1, posicion - 1)
    parte2 = Text.GetSubTextToEnd(expresion, posicion + 3)
    If parte2 <> 0 Then
      Controls.SetTextBoxText(caja, parte1 / parte2)
    Else
      Controls.SetTextBoxText(caja, "Error: div/0")
    EndIf
    GoTo finIgual
  EndIf

  posicion = Text.GetIndexOf(expresion, " ^ ")
  If posicion > 0 Then
    parte1 = Text.GetSubText(expresion, 1, posicion - 1)
    parte2 = Text.GetSubTextToEnd(expresion, posicion + 3)
    Controls.SetTextBoxText(caja, Math.Power(parte1, parte2))
    GoTo finIgual
  EndIf

finIgual:
EndSub

' ══════════════════════════════════════════════════════
' 1. ECUACION CUADRATICA  ax² + bx + c = 0
' ══════════════════════════════════════════════════════
Sub botonCuadratica
  Controls.SetTextBoxText(caja,"Ec.Cuadratica: ax2+bx+c=0")
  Program.Delay(800)
  TextWindow.WriteLine("=== ECUACION CUADRATICA ===")
  TextWindow.WriteLine("Forma: ax2 + bx + c = 0")
  TextWindow.Write("Ingresa a: ")
  va = TextWindow.ReadNumber()
  TextWindow.Write("Ingresa b: ")
  vb = TextWindow.ReadNumber()
  TextWindow.Write("Ingresa c: ")
  vc = TextWindow.ReadNumber()
  If va = 0 Then
    Controls.SetTextBoxText(caja,"Error: a no puede ser 0")
  Else
    discriminante = (vb * vb) - (4 * va * vc)
    If discriminante < 0 Then
      Controls.SetTextBoxText(caja,"Sin solucion real (D<0)")
      TextWindow.WriteLine("No hay raices reales.")
    ElseIf discriminante = 0 Then
      x1 = (-vb) / (2 * va)
      Controls.SetTextBoxText(caja, Text.Append("x = ", x1))
      TextWindow.WriteLine(Text.Append("Una solucion: x = ", x1))
    Else
      x1 = ((-vb) + Math.SquareRoot(discriminante)) / (2 * va)
      x2r = ((-vb) - Math.SquareRoot(discriminante)) / (2 * va)
      res = Text.Append("x1=", x1)
      res = Text.Append(res, "  x2=")
      res = Text.Append(res, x2r)
      Controls.SetTextBoxText(caja, res)
      TextWindow.WriteLine(Text.Append("x1 = ", x1))
      TextWindow.WriteLine(Text.Append("x2 = ", x2r))
    EndIf
  EndIf
EndSub

' ══════════════════════════════════════════════════════
' 2. ECUACION LINEAL  ax + b = 0
' ══════════════════════════════════════════════════════
Sub botonLineal
  Controls.SetTextBoxText(caja,"Ec.Lineal: ax + b = 0")
  Program.Delay(800)
  TextWindow.WriteLine("=== ECUACION LINEAL ===")
  TextWindow.WriteLine("Forma: ax + b = 0")
  TextWindow.Write("Ingresa a: ")
  va = TextWindow.ReadNumber()
  TextWindow.Write("Ingresa b: ")
  vb = TextWindow.ReadNumber()
  If va = 0 Then
    Controls.SetTextBoxText(caja,"Error: a no puede ser 0")
    TextWindow.WriteLine("Error: a no puede ser 0")
  Else
    xr = (-vb) / va
    Controls.SetTextBoxText(caja, Text.Append("x = ", xr))
    TextWindow.WriteLine(Text.Append("x = ", xr))
  EndIf
EndSub

' ══════════════════════════════════════════════════════
' 3. SISTEMA DE 2 ECUACIONES CON 2 INCOGNITAS
' ══════════════════════════════════════════════════════
Sub botonSistema
  Controls.SetTextBoxText(caja,"Sistema 2x2")
  Program.Delay(800)
  TextWindow.WriteLine("=== SISTEMA DE 2 ECUACIONES ===")
  TextWindow.WriteLine("Ec1: a1*x + b1*y = c1")
  TextWindow.WriteLine("Ec2: a2*x + b2*y = c2")
  TextWindow.Write("a1: ")
  a1 = TextWindow.ReadNumber()
  TextWindow.Write("b1: ")
  b1 = TextWindow.ReadNumber()
  TextWindow.Write("c1: ")
  c1 = TextWindow.ReadNumber()
  TextWindow.Write("a2: ")
  a2 = TextWindow.ReadNumber()
  TextWindow.Write("b2: ")
  b2 = TextWindow.ReadNumber()
  TextWindow.Write("c2: ")
  c2 = TextWindow.ReadNumber()
  D = (a1 * b2) - (a2 * b1)
  If D = 0 Then
    Controls.SetTextBoxText(caja,"Sin solucion unica")
    TextWindow.WriteLine("El sistema no tiene solucion unica.")
  Else
    Dx = (c1 * b2) - (c2 * b1)
    Dy = (a1 * c2) - (a2 * c1)
    xr = Dx / D
    yr = Dy / D
    res = Text.Append("x=", xr)
    res = Text.Append(res, "  y=")
    res = Text.Append(res, yr)
    Controls.SetTextBoxText(caja, res)
    TextWindow.WriteLine(Text.Append("x = ", xr))
    TextWindow.WriteLine(Text.Append("y = ", yr))
  EndIf
EndSub

' ══════════════════════════════════════════════════════
' 4. ENERGIA SIN FUERZA NO CONSERVATIVA
' ══════════════════════════════════════════════════════
Sub botonEnergia
  Controls.SetTextBoxText(caja,"Energia mecanica")
  Program.Delay(800)
  TextWindow.WriteLine("=== ENERGIA SIN FUERZA NO CONSERVATIVA ===")
  TextWindow.WriteLine("Ec = 0.5 * m * v2   Ep = m * 9.8 * h")
  TextWindow.Write("Masa (kg): ")
  vm = TextWindow.ReadNumber()
  TextWindow.Write("Velocidad (m/s): ")
  vv = TextWindow.ReadNumber()
  TextWindow.Write("Altura (m): ")
  vh = TextWindow.ReadNumber()
  g = 9.8
  Ec = 0.5 * vm * vv * vv
  Ep = vm * g * vh
  Et = Ec + Ep
  TextWindow.WriteLine(Text.Append("Ec = ", Ec))
  TextWindow.WriteLine(Text.Append("Ep = ", Ep))
  TextWindow.WriteLine(Text.Append("E total = ", Et))
  res = Text.Append("Ec=", Ec)
  res = Text.Append(res, " Ep=")
  res = Text.Append(res, Ep)
  res = Text.Append(res, " Et=")
  res = Text.Append(res, Et)
  Controls.SetTextBoxText(caja, res)
EndSub